# ================================================================
# CPU.sdc — 时序约束文件
# ================================================================
# 输入时钟    : 6.144 MHz 晶振 → 周期 162.760 ns
# PLL 输出 c0 : 48.000 MHz   → 周期 20.833 ns
# ================================================================

# 输入时钟约束
create_clock -name clk_6m -period 162.760 [get_ports clk]

# 自动派生 PLL 输出时钟
derive_pll_clocks

# 时钟不确定性（jitter + skew 估计值）
derive_clock_uncertainty
